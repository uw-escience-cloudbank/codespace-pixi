{
  "name": "CloudBank Workshop",

  // Set pre-build Docker Image
  "image": "ghcr.io/uw-escience-cloudbank/codespace-pixi:sha-b570b93fd3d1f9179d68192e584e581af3ab5eed",
  // Or rebuild on every Codespace start (slower)
  // "build": {
  //   "dockerfile": "Dockerfile",
  //   "context": ".."
  // },

  // Install claude and uv for terminal work
  "features": {
    "ghcr.io/devcontainers/features/node:2.1.0": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    // required for .pixi "mount" option below
    // "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // Prompt each user to set their personal token if not already set
  "secrets": {
    "ANTHROPIC_AUTH_TOKEN": {
      "description": "Your personal LiteLLM virtual key for Claude Code"
    },
    "ANTHROPIC_BASE_URL": {
      "description": "(Pre-set as an organization secret)"
    }
  },

  // Inject env vars — ANTHROPIC_BASE_URL is shared (org secret or hardcoded),
  // ANTHROPIC_AUTH_TOKEN comes from each user's personal Codespaces secret
  "remoteEnv": {
    "ANTHROPIC_BASE_URL": "${localEnv:ANTHROPIC_BASE_URL}",
    "ANTHROPIC_AUTH_TOKEN": "${localEnv:ANTHROPIC_AUTH_TOKEN}",
    // Optional: disable model discovery prompt, enable gateway model list
    // NOTE: can try to enable after liteLLM is updated (https://github.com/BerriAI/litellm/issues/27180)
    "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY": "0",
    // Optional: disable experimental betas if your gateway rejects them
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        // Suppress the "Sign in to Claude" screen since we're using a token
        "claudeCode.disableLoginPrompt": true
      }
    }
  },

  //"mounts": ["source=${localWorkspaceFolderBasename}-pixi,target=${containerWorkspaceFolder}/.pixi,type=volume"],

  "postCreateCommand": {
    //"install-pixi-mount": "sudo chown vscode .pixi && pixi install",
    "install-pixi-nomount": "pixi install",
    // https://code.claude.com/docs/en/model-config#control-the-model-users-run-on
    "claude-settings": "mkdir -p ~/.claude && cp .devcontainer/claude-settings.json ~/.claude/settings.json"
  }
}

